def esc(s): return html.escape(str(s if s is not None else ""))
def rflags(r):
    if r.get("gone"): return "<span class=bad>GONE</span>"
    f=[]; u=r.get("unpushed")
    if isinstance(u,int) and u>0: f.append("<span class=bad>&#8593;%d</span>"%u)
    elif u==-1: f.append("<span class=dim>no-upstream</span>")
    if (r.get("dirty") or 0)>0: f.append("<span class=warn>&#9679;%d</span>"%r["dirty"])
    if (r.get("age_days") or 0)>21 and r.get("branch") not in ("main","master"): f.append("<span class=dim>&#9203;%dd</span>"%r["age_days"])
    if r.get("email_risk"): f.append("<span class=id>id?</span>")
    return " ".join(f) or "<span class=ok>&#10003;</span>"
def rsev(r): return ((r.get("unpushed") or 0)>0,(r.get("dirty") or 0)>0,r.get("gone",False),r.get("age_days") or 0)
def httpcell(c):
    if c in ("-",""," ") or c is None: return "<span class=dim>&mdash;</span>"
    if c=="000": return "<span class=bad>DOWN</span>"
    k=c[:1]; cls="ok" if k in("2","3") else "warn" if k=="4" else "bad" if k=="5" else "dim"
    return "<span class=%s>%s</span>"%(cls,esc(c))
def diskcell(d):
    try: v=int(str(d)[:-1]) if str(d).endswith("%") else int(d)
    except: return "<span class=dim>%s</span>"%esc(d)
    cls="bad" if v>=90 else "warn" if v>=85 else "ok"
    return "<span class=%s>%s</span>"%(cls,esc(d))
rrows="".join("<tr><td>%s</td><td class=dim>%s</td><td>%s</td><td class=dim>%s</td></tr>"%(
    esc(r.get("name")),esc(r.get("branch")),rflags(r),esc(r.get("last"))) for r in sorted(repos,key=rsev,reverse=True))
prows="".join("<tr><td>%s</td><td class=dim>%s</td><td>%s</td><td>%s</td></tr>"%(
    esc(r.get("name")),esc(r.get("url")),httpcell(r.get("code")),diskcell(r.get("disk"))) for r in sorted(prod,key=lambda r:(r.get("code")=="000" or (r.get("code") or "")[:1]=="5"),reverse=True))
nd=sum(1 for r in repos if (r.get("dirty") or 0)>0); nu=sum(1 for r in repos if (r.get("unpushed") or 0)>0)
down=sum(1 for r in prod if r.get("code")=="000" or (r.get("code") or "")[:1]=="5")
tpl="""<!doctype html><meta charset=utf-8><title>Agentic Cockpit</title>
