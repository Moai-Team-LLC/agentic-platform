# ── code-status ───────────────────────────────────────────────────────────────
# Portfolio git panel over your personal repo registry (~/.agentic-cockpit/repos.json).
# HOST-NATIVE: runs git across every repo on disk — no Docker, no platform needed, so
# it works even when the stack is down. Surfaces the risks that pile up across many
# repos solo: unpushed commits (lost work), uncommitted changes, stale feature
# branches, wrong git identity. `--json` emits machine-readable rows (console bridge).
cmd_code_status() {
  local reg="${AGENTIC_COCKPIT_REG:-$HOME/.agentic-cockpit/repos.json}"
  [ -f "$reg" ] || { bad "no repo registry at $(c '1;37' "$reg")"; echo "  seed it with a JSON array of {\"name\",\"path\"} objects, then re-run."; return 1; }
  local mode=table; [ "${1:-}" = "--json" ] && mode=json

  local rows
  rows="$(PYTHONIOENCODING=utf-8 python3 -c 'import json,sys
for r in json.load(open(sys.argv[1],encoding="utf-8")):
    p=r.get("path","")
    if p: print(p+"\t"+(r.get("name") or p.rstrip("/").rsplit("/",1)[-1]))' "$reg")" \
    || { bad "registry is not valid JSON: $reg"; return 1; }

  [ "$mode" = table ] && say "scanning $(printf '%s\n' "$rows" | grep -c .) repos …"
  local now; now="$(date +%s)"
  {
    while IFS=$'\t' read -r p n; do
      [ -n "$p" ] || continue
      if ! git -C "$p" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        printf '%s\t%s\tGONE\t-\t-\t-\t-\tmissing\n' "$p" "$n"; continue   # path gone / not a repo (worktrees OK — .git is a file there)
      fi
      local br dirty ahead last age email er rel
      br="$(git -C "$p" branch --show-current 2>/dev/null)"; [ -z "$br" ] && br='(detached)'
      dirty="$(git -C "$p" status --porcelain 2>/dev/null | grep -c .)"
      ahead="$(git -C "$p" rev-list --count '@{u}..HEAD' 2>/dev/null || echo -)"
      last="$(git -C "$p" log -1 --format=%ct 2>/dev/null || echo "$now")"
      rel="$(git -C "$p" log -1 --format=%cr 2>/dev/null || echo '?')"
      age=$(( (now - last) / 86400 ))
      email="$(git -C "$p" config user.email 2>/dev/null)"
      er='-'; [ "$email" = 'aduchenchuk@gmail.com' ] && er='id?'
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$p" "$n" "$br" "$dirty" "$ahead" "$age" "$er" "$rel"
    done <<< "$rows"
  } | PYTHONIOENCODING=utf-8 python3 -c '
import sys,json,re
rows=[]
for line in sys.stdin:
    line=line.rstrip("\n")
    if not line.strip(): continue
    p,n,br,dirty,ahead,age,er,rel=line.split("\t")
    rows.append(dict(name=n,path=p,branch=br,
        dirty=int(dirty) if dirty.isdigit() else 0,
        unpushed=int(ahead) if ahead.isdigit() else -1,  # -1 = no upstream
        age_days=int(age) if age.lstrip("-").isdigit() else 0,
        email_risk=(er=="id?"), last=rel, gone=(br=="GONE")))
mode=sys.argv[1] if len(sys.argv)>1 else "table"
if mode=="json":
    print(json.dumps(rows,ensure_ascii=False,indent=2)); sys.exit(0)
def col(s,c): return "\033[%sm%s\033[0m"%(c,s)
STALE=21
def is_stale(r): return r["age_days"]>STALE and r["branch"] not in ("main","master")
rows.sort(key=lambda r:(r["unpushed"]>0,r["dirty"]>0,is_stale(r),r["age_days"]),reverse=True)
def flags(r):
    if r["gone"]: return col("GONE","1;31")
    f=[]
    if r["unpushed"]>0: f.append(col("↑%d"%r["unpushed"],"1;31"))
    elif r["unpushed"]<0: f.append(col("no-upstream","2"))
    if r["dirty"]>0: f.append(col("●%d"%r["dirty"],"1;33"))
    if is_stale(r): f.append(col("⧗%dd"%r["age_days"],"2"))
    if r["email_risk"]: f.append(col("id?","1;35"))
    return " ".join(f) if f else col("✓","1;32")
w_n=max([len(r["name"]) for r in rows]+[4])+1
w_b=max([len(r["branch"]) for r in rows]+[6])+1
print()
print("  "+col("%-*s %-*s %-24s %s"%(w_n,"REPO",w_b,"BRANCH","FLAGS","LAST"),"1;37"))
for r in rows:
    fl=flags(r); vis=len(re.sub(r"\033\[[0-9;]*m","",fl))
    print("  %-*s %-*s %s%s %s"%(w_n,r["name"],w_b,r["branch"],fl," "*max(1,24-vis),col(r["last"],"2")))
nd=sum(1 for r in rows if r["dirty"]>0); nu=sum(1 for r in rows if r["unpushed"]>0)
ns=sum(1 for r in rows if is_stale(r)); ng=sum(1 for r in rows if r["gone"])
print()
print("  "+col("%d repos"%len(rows),"1;36")+" · %s dirty · %s unpushed · %d stale(>%dd)%s"%(
    col(nd,"1;33") if nd else "0", col(nu,"1;31") if nu else "0", ns, STALE, (" · %d gone"%ng) if ng else ""))
' "$mode"
}

# ── prod-health ───────────────────────────────────────────────────────────────
# Uptime pane over the registry: HTTP-pings every prod_url, and with --disk also
# ssh's each droplet for root-fs usage. HOST-NATIVE, read-only (GET + `df`), all
# with hard timeouts; probes run sequentially (never fan out hundreds of sockets).
cmd_prod_health() {
  local reg="${AGENTIC_COCKPIT_REG:-$HOME/.agentic-cockpit/repos.json}"
  [ -f "$reg" ] || { bad "no repo registry at $(c '1;37' "$reg")"; return 1; }
  local do_disk=0 mode=table
  for a in "$@"; do case "$a" in --disk) do_disk=1;; --json) mode=json;; esac; done

  local rows
  rows="$(PYTHONIOENCODING=utf-8 python3 -c 'import json,sys,re
for r in json.load(open(sys.argv[1],encoding="utf-8")):
    u=(r.get("prod_url") or "").strip(); ip=(r.get("droplet_ip") or "").strip()
    if u: u=re.split(r"[\s(]", u)[0]   # first clean host — registry urls carry notes / extra domains
    if u or ip: print("\x1f".join([r.get("name",""),u,ip,(r.get("ssh_key") or "").strip()]))' "$reg")" \
    || { bad "registry is not valid JSON: $reg"; return 1; }

  [ "$mode" = table ] && say "probing $(printf '%s\n' "$rows" | grep -c .) prod targets$([ "$do_disk" = 1 ] && echo ' (+disk via ssh)')…"
  {
    while IFS=$'\x1f' read -r n url ip key; do
      [ -n "$n" ] || continue
      local code='-' disk='-' full kp
      if [ -n "$url" ]; then
        case "$url" in http*) full="$url";; *) full="https://$url";; esac
        code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 8 -L "$full" 2>/dev/null)"
        [ -z "$code" ] && code=000   # curl's -w already prints 000 on failure; don't double it
      fi
      if [ "$do_disk" = 1 ] && [ -n "$ip" ] && [ -n "$key" ]; then
        kp="${key/#\~/$HOME}"
        disk="$(ssh -n -i "$kp" -o BatchMode=yes -o ConnectTimeout=6 -o StrictHostKeyChecking=accept-new "root@$ip" \
                 "df -P / | awk 'NR==2{print \$5}'" 2>/dev/null || echo '?')"
        [ -z "$disk" ] && disk='?'
      fi
      printf '%s\t%s\t%s\t%s\n' "$n" "${url:--}" "$code" "$disk"
    done <<< "$rows"
  } | PYTHONIOENCODING=utf-8 python3 -c '
import sys,re,json
rows=[]
for line in sys.stdin:
    line=line.rstrip("\n")
    if not line.strip(): continue
    n,url,code,disk=line.split("\t"); rows.append(dict(name=n,url=url,code=code,disk=disk))
if (sys.argv[1] if len(sys.argv)>1 else "table")=="json":
    print(json.dumps(rows,ensure_ascii=False,indent=2)); sys.exit(0)
def col(s,c): return "\033[%sm%s\033[0m"%(c,s)
def diskpct(d):
    try: return int(d[:-1]) if d.endswith("%") else int(d)
    except: return None
def sev(r):
    c=r["code"]
    if c=="000" or (c and c[:1]=="5"): return 3
    if c and c[:1]=="4": return 2
    dp=diskpct(r["disk"])
    if dp is not None and dp>=85: return 2
    return 0
rows.sort(key=sev,reverse=True)
def codecol(c):
    if c=="-": return col("—","2")
    if c=="000": return col("DOWN","1;31")
    if c[:1] in ("2","3"): return col(c,"1;32")
    if c[:1]=="4": return col(c,"1;33")
    if c[:1]=="5": return col(c,"1;31")
    return c
def diskcol(d):
    dp=diskpct(d)
    if dp is None: return col(d,"2")
    return col(d,"1;31" if dp>=90 else "1;33" if dp>=85 else "1;32")
w_n=max([len(r["name"]) for r in rows]+[4])+1
w_u=max([len(r["url"]) for r in rows]+[8])+1
print()
print("  "+col("%-*s %-*s %-6s %s"%(w_n,"REPO",w_u,"PROD URL","HTTP","DISK"),"1;37"))
for r in rows:
    hv=re.sub(r"\033\[[0-9;]*m","",codecol(r["code"]))
    print("  %-*s %-*s %s%s %s"%(w_n,r["name"],w_u,r["url"],codecol(r["code"])," "*max(1,6-len(hv)),diskcol(r["disk"])))
down=sum(1 for r in rows if r["code"]=="000" or (r["code"] and r["code"][:1]=="5"))
warn=sum(1 for r in rows if (r["code"] and r["code"][:1]=="4") or (diskpct(r["disk"]) or 0)>=85)
print()
print("  "+col("%d targets"%len(rows),"1;36")+" · %s down · %s warn"%(
    col(down,"1;31") if down else "0", col(warn,"1;33") if warn else "0"))
' "$mode"
}

# ── deploy ────────────────────────────────────────────────────────────────────
# Registry-driven deploy for a repo. Read-first: prints the exact command it WOULD
# run (always prefixed with `cd <repo> &&` — defeats the rsync-CWD footgun where a
# deploy script's relative paths hit the wrong tree). --run actually executes it.
cmd_deploy() {
  local reg="${AGENTIC_COCKPIT_REG:-$HOME/.agentic-cockpit/repos.json}"
  [ -f "$reg" ] || { bad "no repo registry at $(c '1;37' "$reg")"; return 1; }
  local name='' run=0
  for a in "$@"; do case "$a" in --run) run=1;; *) [ -z "$name" ] && name="$a";; esac; done
  [ -n "$name" ] || { bad "usage: agentic deploy <repo> [--run]"; return 1; }

  local rec
  rec="$(PYTHONIOENCODING=utf-8 python3 -c 'import json,sys
q=sys.argv[2].lower()
data=json.load(open(sys.argv[1],encoding="utf-8"))
m=[r for r in data if r.get("name","").lower()==q] or [r for r in data if q in r.get("name","").lower()]
if not m: sys.exit(3)
if len(m)>1: sys.stderr.write(", ".join(r.get("name","") for r in m)); sys.exit(4)
r=m[0]
print("\x1f".join([r.get("name",""),r.get("path",""),r.get("deploy_cmd") or "",r.get("prod_branch") or "",r.get("prod_url") or ""]))' "$reg" "$name" 2>/tmp/agentic_deploy_err)"
  local rc=$?
  [ $rc -eq 3 ] && { bad "no repo matching '$name' in registry"; return 1; }
  [ $rc -eq 4 ] && { bad "ambiguous '$name' — matches: $(cat /tmp/agentic_deploy_err)"; return 1; }
  [ $rc -ne 0 ] && { bad "registry read failed"; return 1; }

  local rn rpath rcmd rbranch rurl
  IFS=$'\x1f' read -r rn rpath rcmd rbranch rurl <<< "$rec"
  say "deploy target: $(c '1;37' "$rn")"
  echo "  path:   ${rpath:-—}"
  echo "  branch: ${rbranch:-—}   prod: ${rurl:-—}"
  if [ -z "$rcmd" ]; then
    warn "no deploy_cmd set for '$rn' — add one to the registry to enable --run"; return 0
  fi
  local full="cd $(printf '%q' "$rpath") && $rcmd"   # ALWAYS force cd first
  echo ""; echo "  $(c '1;36' 'command:') $full"
  if [ "$run" = 1 ]; then
    [ -d "$rpath" ] || { bad "path does not exist: $rpath"; return 1; }
    echo ""; say "running…"; bash -c "$full"
  else
    echo ""; echo "  $(c '2' 'dry-run — add --run to execute')"
  fi
}

# ── cockpit ───────────────────────────────────────────────────────────────────
# Render a self-contained HTML panel of the whole portfolio (git + prod health)
# from the registry and open it. HOST-NATIVE by design: the platform console runs
# in a container that can't see your host repos, so the visual panel is generated
# on the host from the same --json the CLI already emits — no container, no risk.
cmd_cockpit() {
  local reg="${AGENTIC_COCKPIT_REG:-$HOME/.agentic-cockpit/repos.json}"
  [ -f "$reg" ] || { bad "no repo registry at $(c '1;37' "$reg")"; return 1; }
  local out="${AGENTIC_COCKPIT_HTML:-$HOME/.agentic-cockpit/cockpit.html}"
  say "collecting portfolio (git × N + prod pings)…"
  local repos prod
  repos="$(cmd_code_status --json 2>/dev/null)"
  prod="$(cmd_prod_health --json 2>/dev/null)"
  REPOS_JSON="$repos" PROD_JSON="$prod" PYTHONIOENCODING=utf-8 python3 -c '
import os,json,html,datetime
repos=json.loads(os.environ.get("REPOS_JSON") or "[]")
prod=json.loads(os.environ.get("PROD_JSON") or "[]")
