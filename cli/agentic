    sips -Z $s "$ROOT/console/web/icon-512.png" --out "$iconset/icon_${s}x${s}.png" >/dev/null 2>&1
    sips -Z $((s*2)) "$ROOT/console/web/icon-512.png" --out "$iconset/icon_${s}x${s}@2x.png" >/dev/null 2>&1
  done
  iconutil -c icns "$iconset" -o "$app/Contents/Resources/icon.icns" 2>/dev/null && ok "icon baked" || warn "icns failed (app still works)"
  touch "$app"  # nudge Finder/LaunchServices to refresh
