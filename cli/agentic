#!/usr/bin/env bash
#
# agentic — the Agentic Platform control plane (Docker-native).
# One command brings up the whole ecosystem as durable containers, wired: every
# LLM call flows through AgenticGateway, every trace into AgenticPerformance.
# Run `agentic` with no args for the full command list.
#
set -uo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENVF="$ROOT/.env"
COMPOSE_FILE="$ROOT/deploy/docker-compose.yml"
BACKUP_DIR="${AGENTIC_BACKUP_DIR:-$HOME/.agentic-backups}"   # OUTSIDE the repo — never git-committed
dc() { docker compose -f "$COMPOSE_FILE" --env-file "$ENVF" "$@"; }

c() { printf "\033[%sm%s\033[0m" "$1" "$2"; }
say() { echo "$(c '1;36' '▸') $*"; }
ok()  { echo "  $(c '1;32' '✓') $*"; }
warn(){ echo "  $(c '1;33' '!') $*"; }
bad() { echo "  $(c '1;31' '✗') $*"; }

load_env() {
  [ -f "$ENVF" ] || { say "creating .env from template"; sed "s#\${HOME}#$HOME#g" "$ROOT/integration/platform.env.example" > "$ENVF"; }
  set -a; . "$ENVF"; set +a
  : "${MIND_PORT:=4390}" "${APL_INGEST_PORT:=4319}" "${GATEWAY_PORT:=8787}" "${BIFROST_PORT:=4380}" "${CONSOLE_PORT:=4600}"
  : "${MIND_PG_PORT:=5435}" "${APL_PG_PORT:=5439}" "${OPS_PORT:=4700}"
  : "${EMBED_CACHE_DIR:=$HOME/.cache/agenticmind-embed}"
  # instance identity + service profiles (an engine per product = its own name,
  # ports and profile set; the platform's own instance is the default)
  export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-agentic-platform}"
  export COMPOSE_PROFILES="${COMPOSE_PROFILES:-fleet,scan}"
  [ -n "${OPENROUTER_API_KEY:-}" ] || { warn "OPENROUTER_API_KEY is empty in $ENVF"; return 1; }
}
setenv() { local v="$1" val="$2"; grep -q "^$v=" "$ENVF" && perl -i -pe "s#^$v=.*#$v=$val#" "$ENVF" || printf '%s=%s\n' "$v" "$val" >> "$ENVF"; }
# generate a secret only if missing; persist via setenv (append-or-replace) so it
# is written even when the .env line is absent, not just when it's present-but-empty.
gen_secret() { local v="$1" val; val="$(grep -E "^$v=" "$ENVF" | cut -d= -f2-)"; [ -z "$val" ] && { val="$(openssl rand -hex 32)"; setenv "$v" "$val"; export "$v=$val"; }; return 0; }
wait_h() { local url="$1" name="$2" i=0; until curl -fsS --max-time 2 "$url" >/dev/null 2>&1 || [ $i -ge 60 ]; do sleep 2; i=$((i+1)); done; if curl -fsS --max-time 2 "$url" >/dev/null 2>&1; then ok "$name up"; return 0; else warn "$name not healthy — agentic logs"; return 1; fi; }
json_str() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }
# extract the answer text from an MCP streamable-HTTP (SSE) response on stdin.
# Uses `python3 -c` (NOT a heredoc) so the piped curl output stays python's stdin.
mcp_text() {
  PYTHONIOENCODING=utf-8 python3 -c '
import sys, json
raw = sys.stdin.read()
for part in raw.split("data:"):
    part = part.strip()
    if not part.startswith("{"): continue
    try: d = json.loads(part)
    except Exception: continue
    r = d.get("result")
    if not r: continue
    t = (r.get("content") or [{}])[0].get("text", "")
    try: t = json.loads(t).get("answer", t)
    except Exception: pass
    print(t); break
'
}
# Is the persisted gateway tenant key still valid? The gateway authenticates at the
# edge before routing, so a bad key => 401/403; a good key with a deliberately
# invalid body => a non-auth error. This validates the key WITHOUT spending on a model.
gw_key_ok() {
  [ -n "${MIND_GATEWAY_KEY:-}" ] || return 1
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 5 -X POST "http://127.0.0.1:${GATEWAY_PORT:-8787}/v1/chat/completions" \
    -H "Authorization: Bearer $MIND_GATEWAY_KEY" -H "Content-Type: application/json" -d '{"model":"__ping__","messages":[]}' 2>/dev/null)"
  [ "$code" != "401" ] && [ "$code" != "403" ]
}

cmd_up() {
  load_env || return 1
  gen_secret AUTH_SECRET; gen_secret AGW_VAULT_KEY
  mkdir -p "$EMBED_CACHE_DIR" "$ROOT/.run"
  local fails=0

  # pre-migration snapshot: if the memory volume already exists, bring up only the
  # DBs, snapshot them, THEN proceed (mind-migrate runs during the full up below).
  if docker volume inspect agentic-platform_mind-pgdata >/dev/null 2>&1; then
    say "Snapshotting data before migrations"
    dc up -d mind-db apl-db >/dev/null 2>&1
    local i=0; until dc exec -T mind-db pg_isready -U postgres >/dev/null 2>&1 || [ $i -ge 30 ]; do sleep 1; i=$((i+1)); done
    cmd_backup quiet && ok "snapshot saved → $BACKUP_DIR" || warn "pre-migration snapshot skipped"
  fi

  # 1. data plane + gateway first, so we can mint a tenant key before Mind/APL start.
  say "Model plane (Bifrost + Gateway)"
  if ! dc up -d --build bifrost gateway; then bad "gateway/bifrost build or start failed — run: agentic logs gateway"; return 1; fi
  wait_h "http://127.0.0.1:$GATEWAY_PORT/health" "Gateway" || fails=$((fails+1))

  # 2. mint (or re-mint) the platform tenant key: mint if unset OR if the persisted
  #    key no longer validates (e.g. the gateway-data volume was recreated).
  if [ -n "${MIND_GATEWAY_KEY:-}" ] && ! gw_key_ok; then
    warn "persisted gateway key is stale — re-minting"; setenv MIND_GATEWAY_KEY ""; export MIND_GATEWAY_KEY=""
  fi
  if [ -z "${MIND_GATEWAY_KEY:-}" ]; then
    say "Minting the platform Gateway tenant"
    local key; key="$(dc exec -T gateway bun run src/cli.ts tenant create agenticmind --budget-usd 100 2>/dev/null | grep -oE 'sk-agw-[A-Za-z0-9_-]+' | head -1)"
    dc exec -T gateway bun run src/cli.ts routing sync --from-file fixtures/apl-eval-export.example.json >/dev/null 2>&1 || true
    [ -n "$key" ] && { setenv MIND_GATEWAY_KEY "$key"; export MIND_GATEWAY_KEY="$key"; ok "tenant key minted + wired"; } || warn "tenant mint failed — chat via gateway may 401"
  fi

  # 3. the rest of the stack, now with the key in .env
  say "Bringing up the full stack"
  if ! dc up -d --build; then bad "stack build or start failed — run: agentic logs"; return 1; fi
  wait_h "http://127.0.0.1:$MIND_PORT/health" "AgenticMind" || fails=$((fails+1))
  wait_h "http://127.0.0.1:$APL_INGEST_PORT/health" "AgenticPerformance" || fails=$((fails+1))
  wait_h "http://127.0.0.1:$CONSOLE_PORT/api/health" "Console" || fails=$((fails+1))

  # 4. arm the heartbeat: mint an MCP token so traces + cost stay live on their own
  if [ -z "${HEARTBEAT_TOKEN:-}" ]; then
    say "Arming the heartbeat (live traces + cost)"
    local ht; ht="$(cmd_token heartbeat 2>/dev/null | grep -oE 'ey[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+' | tail -1)"
    [ -n "$ht" ] && { setenv HEARTBEAT_TOKEN "$ht"; export HEARTBEAT_TOKEN="$ht"; dc up -d >/dev/null 2>&1; ok "MCP token armed (console ask + any fleet/heartbeat in this profile)"; } || warn "heartbeat token mint failed"
  fi

  echo
  if [ "$fails" -eq 0 ]; then
    ok "Platform up. Console → $(c '1;4;36' "http://127.0.0.1:$CONSOLE_PORT")"
    echo "     Try: agentic ask \"…\"   ·   agentic doctor   ·   agentic status"
  else
    warn "Platform is DEGRADED — $fails core service(s) not healthy. Run: agentic doctor"
    return 1
  fi
}

cmd_down()   { load_env 2>/dev/null || true; say "Stopping the stack (volumes preserved — your memory is safe)"; dc down >/dev/null 2>&1; ok "down"; }
cmd_logs()   { load_env 2>/dev/null || true; dc logs --tail 50 "${1:-console}" 2>/dev/null; }
cmd_console(){ load_env 2>/dev/null || true; echo "http://127.0.0.1:${CONSOLE_PORT:-4600}"; command -v open >/dev/null && open "http://127.0.0.1:${CONSOLE_PORT:-4600}" 2>/dev/null || true; }
cmd_demo()   { load_env || return 1; bash "$ROOT/examples/closed-loop.sh"; }
cmd_token() {
  load_env || return 1
  # Mint INSIDE the running mind container: its image carries the workspace deps and
  # DATABASE_URL/AUTH_SECRET, so this works from a FRESH CLONE with no host-side
  # `bun install` of the AgenticMind monorepo (which the host path required).
  dc cp "$ROOT/vendor/AgenticMind/scripts/issue-mcp-token.ts" mind-server:/app/apps/server/_mint.ts >/dev/null 2>&1 \
    || { warn "mind engine not up — run: agentic up"; return 1; }
  dc exec -T -w /app/apps/server mind-server bun run _mint.ts --label "${1:-platform}" --ttl-days 365
}

# aggregate health verdict + per-service states — the fast "is it ok?" from the terminal
cmd_status() {
  load_env 2>/dev/null || true
  local h; h="$(curl -fsS --max-time 3 "http://127.0.0.1:${CONSOLE_PORT:-4600}/api/health" 2>/dev/null || true)"
  if [ -n "$h" ]; then
    # honest count: real services only (contract/library nodes can never be down)
    local upn totn
    read -r upn totn <<< "$(printf '%s' "$h" | PYTHONIOENCODING=utf-8 python3 -c '
import json,sys
try: d=json.load(sys.stdin)
except Exception: print(0,0); raise SystemExit
svc=[v for v in d.values() if isinstance(v,dict) and v.get("kind") not in ("contract","library") and v.get("active") is not False]
print(sum(1 for v in svc if v.get("up")), len(svc))' 2>/dev/null)"
    if [ "$upn" = "$totn" ] && [ "${totn:-0}" != "0" ]; then echo "$(c '1;32' "● $upn/$totn services up")"; else echo "$(c '1;33' "● DEGRADED — $upn/$totn up  (agentic doctor)")"; fi
  else
    echo "$(c '1;31' "● console unreachable — is the platform up?  (agentic up)")"
  fi
  dc ps --format '  {{.Service}}\t{{.State}}\t{{.Status}}' 2>/dev/null
}

# end-to-end readiness: containers running + gateway routes + Claude's MCP path works
cmd_doctor() {
  load_env || return 1
  local fail=0
  say "Doctor — end-to-end readiness"
  local notrun; notrun="$(dc ps --format '{{.Service}}={{.State}}' 2>/dev/null | grep -v '=running' | grep -vE 'mind-migrate|apl-migrate' || true)"
  if [ -z "$notrun" ]; then ok "containers: all running"; else bad "not running: $(echo "$notrun" | tr '\n' ' ')"; fail=1; fi
  local rc; rc="$(curl -fsS --max-time 25 -X POST "http://127.0.0.1:${GATEWAY_PORT:-8787}/v1/chat/completions" \
    -H "Authorization: Bearer ${MIND_GATEWAY_KEY:-}" -H "Content-Type: application/json" \
    -d '{"model":"openrouter/openai/gpt-4o-mini","messages":[{"role":"user","content":"reply OK"}],"max_tokens":3}' 2>/dev/null || true)"
  if printf '%s' "$rc" | grep -q '"choices"'; then ok "gateway → OpenRouter routing works (spent a few cents)"; else bad "gateway routing FAILED (stale key or upstream down) — agentic logs gateway"; fail=1; fi
  local tl; tl="$(curl -fsS --max-time 8 -X POST "http://127.0.0.1:${MIND_PORT:-4390}/mcp" \
    -H "Authorization: Bearer ${HEARTBEAT_TOKEN:-}" -H "Content-Type: application/json" -H "Accept: application/json, text/event-stream" \
    -d '{"jsonrpc":"2.0","id":1,"method":"tools/list"}' 2>/dev/null || true)"
  if printf '%s' "$tl" | grep -q 'kl_ask_global'; then ok "Claude's MCP path (AgenticMind) works — tools present"; else bad "MCP tools/list FAILED — Claude can't reach Mind (token stale? run: agentic up)"; fail=1; fi
  echo
  [ "$fail" -eq 0 ] && ok "All readiness checks passed." || { warn "Some checks FAILED — see above."; return 1; }
}

# ask AgenticMind a question from the terminal (uses the persisted heartbeat MCP token)
cmd_ask() {
  load_env || return 1
  local q="$*"
  [ -n "$q" ] || { warn "usage: agentic ask \"your question\""; return 1; }
  [ -n "${HEARTBEAT_TOKEN:-}" ] || { warn "no MCP token yet — run: agentic up"; return 1; }
  local body; body="$(printf '{"jsonrpc":"2.0","id":1,"method":"tools/call","params":{"name":"kl_ask_global","arguments":{"question":%s}}}' "$(json_str "$q")")"
  curl -fsS --max-time 40 -X POST "http://127.0.0.1:${MIND_PORT:-4390}/mcp" \
    -H "Authorization: Bearer $HEARTBEAT_TOKEN" -H "Content-Type: application/json" -H "Accept: application/json, text/event-stream" \
    -d "$body" 2>/dev/null | mcp_text
}

# ingest a file — or every .md/.txt in a directory — into the knowledge base.
# Each file is chunked, embedded, and distilled into fact cards (kl_ingest).
# Large files (>40 KB) are auto-split into ~20 KB parts on paragraph boundaries —
# a single kl_ingest of 100 KB+ times out on card extraction.
cmd_ingest() {
  load_env || return 1
  [ -n "${HEARTBEAT_TOKEN:-}" ] || { warn "no MCP token — run: agentic up"; return 1; }
  local target="${1:-}"
  [ -n "$target" ] || { warn "usage: agentic ingest <file-or-directory>"; return 1; }
  local files=()
  if [ -d "$target" ]; then
    while IFS= read -r f; do files+=("$f"); done < <(find "$target" -type f \( -name '*.md' -o -name '*.txt' -o -name '*.markdown' \) | sort)
  else
    files=("$@")   # a single file, or a shell-expanded glob
  fi
  local total=${#files[@]} okn=0 failn=0
  [ "$total" -gt 0 ] || { warn "no .md/.txt files found under $target"; return 1; }
  say "Ingesting $total file(s) into AgenticMind (chunk → embed → distil)"
  for f in "${files[@]}"; do
    [ -f "$f" ] && [ -s "$f" ] || { warn "skip $(basename "$f") (missing/empty)"; continue; }
    # python writes one JSON-RPC body per chunk to a temp file and prints "<title>\t<path>"
    # (temp files keep large bodies out of the shell + avoid base64 -d/-D portability)
    local chunks
    chunks="$(python3 - "$f" "$(basename "${f%.*}")" <<'PY'
import sys, os, json, tempfile
path, title = sys.argv[1], sys.argv[2]
text = open(path, encoding="utf-8").read()
MAX, SIZE = 40000, 20000
def emit(t, x):
    fd, p = tempfile.mkstemp(suffix=".json", prefix="aging_")
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        json.dump({"jsonrpc":"2.0","id":1,"method":"tools/call",
                   "params":{"name":"kl_ingest","arguments":{"title":t,"text":x}}}, fh)
    print(t + "\t" + p)
if len(text.encode()) <= MAX:
    emit(title, text)
else:
    parts, cur = [], ""
    for para in text.split("\n\n"):
        if cur and len((cur + "\n\n" + para).encode()) > SIZE:
            parts.append(cur); cur = para
        else:
            cur = (cur + "\n\n" + para) if cur else para
    if cur: parts.append(cur)
    for i, part in enumerate(parts, 1):
        emit("%s (part %d/%d)" % (title, i, len(parts)), part)
PY
)"
    local any_fail=0
    while IFS=$'\t' read -r ctitle cpath; do
      [ -n "$cpath" ] || continue
      local resp
      resp="$(curl -fsS --max-time 150 -X POST "http://127.0.0.1:${MIND_PORT:-4390}/mcp" \
        -H "Authorization: Bearer $HEARTBEAT_TOKEN" -H "Content-Type: application/json" -H "Accept: application/json, text/event-stream" \
        --data-binary @"$cpath" 2>/dev/null)"
      rm -f "$cpath"
      if printf '%s' "$resp" | grep -q '"result"' && ! printf '%s' "$resp" | grep -q '"isError":true'; then ok "$ctitle"; else any_fail=1; bad "$ctitle"; fi
    done <<< "$chunks"
    [ "$any_fail" -eq 0 ] && okn=$((okn+1)) || failn=$((failn+1))
  done
  echo; ok "ingested $okn/$total file(s) fully (failed $failn) — console Knowledge pane / agentic ask \"…\""
}

# dump every database (Mind memory, APL traces, SHO incidents) + the gateway ledger.
# Writes OUTSIDE the repo so a `git add -A` can never leak private memory.
cmd_backup() {
  load_env 2>/dev/null || true
  local quiet="${1:-}"
  local ts dir; ts="$(date +%Y%m%d-%H%M%S)"; dir="$BACKUP_DIR/$ts"; mkdir -p "$dir"
  [ "$quiet" = quiet ] || say "Backing up databases → $dir"
  dc exec -T mind-db pg_dump -U postgres --clean --if-exists postgres 2>/dev/null | gzip > "$dir/mind.sql.gz"
  dc exec -T apl-db  pg_dump -U postgres --clean --if-exists postgres 2>/dev/null | gzip > "$dir/apl.sql.gz"
  dc cp gateway:/data/agw.db "$dir/agw.db" >/dev/null 2>&1 || true
  dc cp gateway:/data/evidence.jsonl "$dir/evidence.jsonl" >/dev/null 2>&1 || true
  ls -1dt "$BACKUP_DIR"/*/ 2>/dev/null | tail -n +15 | xargs -I{} rm -rf {} 2>/dev/null || true   # keep last 14
  if [ ! -s "$dir/mind.sql.gz" ] || [ "$(gzip -dc "$dir/mind.sql.gz" 2>/dev/null | wc -c | tr -d ' ')" -lt 100 ]; then
    [ "$quiet" = quiet ] || warn "mind dump looks empty — is the platform up?"
    return 1
  fi
  [ "$quiet" = quiet ] || ok "backed up (mind $(du -h "$dir/mind.sql.gz" | cut -f1) + apl + gateway) → $dir"
}

# restore the databases from a backup directory (overwrites current data)
cmd_restore() {
  load_env || return 1
  local dir="${1:-}"
  [ -n "$dir" ] && [ -d "$dir" ] || { warn "usage: agentic restore <backup-dir>"; echo "  available:"; ls -1dt "$BACKUP_DIR"/*/ 2>/dev/null | head -8 | sed 's/^/    /'; return 1; }
  say "Restoring databases from $dir  (current data will be overwritten)"
  [ -f "$dir/mind.sql.gz" ] && gzip -dc "$dir/mind.sql.gz" | dc exec -T mind-db psql -q -U postgres postgres >/dev/null 2>&1 && ok "mind restored"
  [ -f "$dir/apl.sql.gz" ]  && gzip -dc "$dir/apl.sql.gz"  | dc exec -T apl-db  psql -q -U postgres postgres >/dev/null 2>&1 && ok "apl restored"
  ok "restore complete"
}

# stamp a NEW engine instance for a product/client: its own name, ports, secrets
# and service profiles. Run in a fresh clone: agentic init <name> [port-base] [profiles]
#   name       [a-z0-9-]: names containers/volumes/network (isolation per instance)
#   port-base  optional; assigns sequential host ports from base (two engines on
#              one machine can't share ports). Omit on a dedicated server.
#   profiles   optional, default "scan" (core always runs; "fleet" is the
#              platform's own dogfood agents — product engines usually skip it)
cmd_init() {
  local name="${1:-}" base="${2:-}" profiles="${3:-scan}"
  [ -n "$name" ] || { warn "usage: agentic init <name> [port-base] [profiles]"; return 1; }
  printf '%s' "$name" | grep -qE '^[a-z0-9][a-z0-9-]*$' || { warn "name must be [a-z0-9-]"; return 1; }
  if [ -f "$ENVF" ] && grep -q '^COMPOSE_PROJECT_NAME=' "$ENVF"; then
    warn "already initialized as '$(grep '^COMPOSE_PROJECT_NAME=' "$ENVF" | cut -d= -f2)' — refusing to overwrite .env"; return 1
  fi
  [ -f "$ENVF" ] || sed "s#\${HOME}#$HOME#g" "$ROOT/integration/platform.env.example" > "$ENVF"
  setenv COMPOSE_PROJECT_NAME "$name-engine"
  setenv COMPOSE_PROFILES "$profiles"
  if [ -n "$base" ]; then
    setenv MIND_PORT "$((base+0))";  setenv GATEWAY_PORT "$((base+1))"; setenv BIFROST_PORT "$((base+2))"
    setenv APL_INGEST_PORT "$((base+3))"; setenv CONSOLE_PORT "$((base+4))"
    setenv OPS_PORT "$((base+6))"; setenv MIND_PG_PORT "$((base+7))"; setenv APL_PG_PORT "$((base+8))"
  fi
  gen_secret AUTH_SECRET; gen_secret AGW_VAULT_KEY
  ok "instance '$name-engine' initialized (profiles: core+$profiles$( [ -n "$base" ] && echo ", ports $base-$((base+8))" ))"
  echo "     next: 1) put OPENROUTER_API_KEY=… into .env"
  echo "           2) agentic up        3) agentic doctor        4) agentic handout"
}

# write the integration handout for the product team: every endpoint + credential
# their app needs to plug into this engine. Contains secrets → handout.md is gitignored.
cmd_handout() {
  load_env || return 1
  local f="$ROOT/handout.md"
  say "Minting a dedicated MCP token for the integration"
  local tok; tok="$(cmd_token "$COMPOSE_PROJECT_NAME-integration" 2>/dev/null | grep -oE 'ey[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+' | tail -1)"
  [ -n "$tok" ] || { warn "token mint failed — is the engine up?"; return 1; }
  cat > "$f" <<EOF
# ${COMPOSE_PROJECT_NAME} — integration handout
_Generated by \`agentic handout\`. Contains credentials — do not commit._

## Console (observability)
http://127.0.0.1:${CONSOLE_PORT}

## Knowledge & memory (AgenticMind, MCP)
- Endpoint: \`http://127.0.0.1:${MIND_PORT}/mcp\` (streamable HTTP)
- Bearer token: \`${tok}\`
- Tools: kl_search · kl_ask_global · kl_get_material · kl_ingest · kl_forget · mem_recall · mem_write · mem_forget · kl_signal
- Claude Code wiring (~/.claude.json → mcpServers):
  \`{"type":"http","url":"http://127.0.0.1:${MIND_PORT}/mcp","headers":{"Authorization":"Bearer <token>"}}\`

## Model plane (AgenticGateway — OpenAI-compatible)
- Base URL: \`http://127.0.0.1:${GATEWAY_PORT}/v1\`
- API key: \`${MIND_GATEWAY_KEY:-<mint: bun run src/cli.ts tenant create …>}\`
- Model slugs: passthrough, e.g. \`openrouter/openai/gpt-4o-mini\`
- Every call is budgeted + landed in the cost ledger (Console → Model plane)

## Traces (AgenticPerformance, OTLP)
- OTLP endpoint: \`http://127.0.0.1:${APL_INGEST_PORT}\` (set OTEL_EXPORTER_OTLP_ENDPOINT)
- Attribute your agents with \`gen_ai.agent.id\`

## Operations
- Health: \`agentic status\` · end-to-end: \`agentic doctor\`
- Backup: \`agentic backup\` → ~/.agentic-backups (restore: \`agentic restore <dir>\`)
EOF
  ok "handout → $f  (gitignored; hand it to the product team)"
}

# show how far each vendored submodule is behind its upstream (read-only)
cmd_outdated() {
  cd "$ROOT"
  local paths; paths="$(git config -f .gitmodules --get-regexp path | awk '{print $2}')"
  say "Vendored engine parts vs upstream"
  for p in $paths; do
    git -C "$p" fetch -q origin 2>/dev/null
    git -C "$p" remote set-head origin -a >/dev/null 2>&1 || true
    local up n; up="$(git -C "$p" rev-parse --short origin/HEAD 2>/dev/null || git -C "$p" rev-parse --short origin/main 2>/dev/null)"
    n="$(git -C "$p" rev-list --count HEAD..origin/HEAD 2>/dev/null || echo 0)"
    if [ "${n:-0}" = "0" ]; then ok "${p#vendor/} — up to date"; else warn "${p#vendor/} — behind $n (pin $(git -C "$p" rev-parse --short HEAD) → $up)"; fi
  done
}

# deliberately absorb upstream: snapshot → bump pins to upstream latest → rebuild →
# migrate (up auto-snapshots) → doctor. Pins stay reproducible; you review + commit.
#   agentic update [name...]   default: all submodules that are behind
cmd_update() {
  load_env || return 1
  cd "$ROOT"
  say "Snapshotting before absorbing upstream (safety)"
  cmd_backup quiet 2>/dev/null || warn "backup skipped (engine down?) — proceeding"
  local paths; paths="$(git config -f .gitmodules --get-regexp path | awk '{print $2}')" any=0
  for p in $paths; do
    local nm="${p#vendor/}"
    [ -z "$*" ] || printf ' %s ' "$*" | grep -q " $nm " || continue
    git -C "$p" fetch -q origin 2>/dev/null
    git -C "$p" remote set-head origin -a >/dev/null 2>&1 || true
    local up n; up="$(git -C "$p" rev-parse origin/HEAD 2>/dev/null || git -C "$p" rev-parse origin/main 2>/dev/null)"
    n="$(git -C "$p" rev-list --count "HEAD..$up" 2>/dev/null || echo 0)"
    [ "${n:-0}" = "0" ] && continue
    any=1; say "$nm: +$n"
    git -C "$p" log --oneline --no-decorate "HEAD..$up" | sed 's/^/    /'
    git -C "$p" checkout -q "$up"
  done
  [ "$any" = "0" ] && { ok "already up to date — nothing to absorb"; return 0; }
  say "Rebuilding + migrating (pre-migration snapshot runs inside up)"
  cmd_up || { bad "up failed after bump — ROLLBACK: git submodule update --recursive && agentic restore <~/.agentic-backups/…>"; return 1; }
  say "Verifying end-to-end"; cmd_doctor || warn "doctor flagged issues — review before committing the pins"
  echo
  ok "upstream absorbed + verified. Version the new pins:"
  echo "     git add vendor && git commit -m 'chore(vendor): bump engine submodules' && git push"
  echo "     then each product engine: git pull && agentic sync"
}

# apply the committed submodule pins (after `git pull`, or on a fresh clone) + rebuild.
# This is how a product engine absorbs pins the platform already versioned — reproducible.
cmd_sync() {
  load_env || return 1
  cd "$ROOT"
  say "Syncing submodules to the committed pins"
  git submodule sync --quiet
  git submodule update --init --recursive || { bad "submodule update failed"; return 1; }
  say "Rebuilding + migrating"; cmd_up && cmd_doctor
}

# put `agentic` on PATH (no sudo — ~/.local/bin)
cmd_install() {
  local dest="$HOME/.local/bin"; mkdir -p "$dest"
  ln -sf "$ROOT/cli/agentic" "$dest/agentic"; ok "linked → $dest/agentic"
  case ":$PATH:" in
    *":$dest:"*) ok "$dest is already on PATH — run: agentic up" ;;
    *) warn "add $dest to PATH:  echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.zshrc && source ~/.zshrc" ;;
  esac
}

