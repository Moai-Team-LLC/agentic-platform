<div class=card><b class=bad>@@NU@@</b><span>unpushed</span></div>
<div class=card><b class=bad>@@DOWN@@</b><span>prod down</span></div>
</div>
<h2>Repositories</h2>
<table><tr><th>repo</th><th>branch</th><th>flags</th><th>last commit</th></tr>@@RROWS@@</table>
<h2>Production</h2>
<table><tr><th>repo</th><th>url</th><th>http</th><th>disk</th></tr>@@PROWS@@</table>
"""
out=(tpl.replace("@@NOW@@",now).replace("@@NREPO@@",str(len(repos))).replace("@@NPROD@@",str(len(prod)))
     .replace("@@ND@@",str(nd)).replace("@@NU@@",str(nu)).replace("@@DOWN@@",str(down))
     .replace("@@RROWS@@",rrows).replace("@@PROWS@@",prows))
print(out)
' > "$out"
  [ $? -eq 0 ] && [ -s "$out" ] || { bad "failed to render panel"; return 1; }
  ok "cockpit → $(c '1;4;36' "file://$out")"
  command -v open >/dev/null && open "$out" 2>/dev/null || true
}

usage() {
  cat <<'USAGE'
agentic — the Agentic Platform control plane

  agentic init <name> [port-base] [profiles]
                           stamp a NEW engine instance (own name/ports/secrets/profiles)
  agentic handout          write handout.md — endpoints + creds for the product team
  agentic up               build + start the whole stack, wired
  agentic down             stop the stack (data volumes preserved)
  agentic status           aggregate health verdict + per-service states
  agentic code-status      portfolio git status across all your repos (host, registry-driven)
  agentic prod-health [--disk]  ping every prod URL (+ ssh droplet disk) from the registry
  agentic deploy <repo> [--run] show (or run) a repo's deploy command, forced `cd` into it
  agentic cockpit          render + open the HTML portfolio panel (git + prod, host-native)
  agentic doctor           end-to-end readiness (routing + Claude's MCP path)
  agentic ask "question"   ask AgenticMind a question from the terminal
  agentic ingest <path>    add a file / a directory of .md,.txt into the knowledge base
  agentic backup           dump all databases → ~/.agentic-backups
  agentic restore <dir>    restore databases from a backup directory
  agentic outdated         show how far vendored parts are behind upstream
  agentic update [name…]   absorb upstream: snapshot → bump pins → rebuild → verify
  agentic sync             apply committed pins (after git pull / fresh clone) + rebuild
  agentic console          open the console (http://127.0.0.1:4600)
  agentic app              open the console as a desktop-style window (Chrome app mode)
  agentic dockapp          create ~/Applications/Agentic Console.app + pin it to the Dock
  agentic menubar          install the menu-bar control (SwiftBar: health + start/stop)
  agentic demo             run the closed-loop demo (ask → route → trace → scan)
  agentic token [label]    mint an MCP token for AgenticMind (for Claude Code)
  agentic install          put `agentic` on your PATH (~/.local/bin)
  agentic logs [service]   tail a service's logs
USAGE
}

case "${1:-}" in
  init) shift; cmd_init "$@" ;; handout) cmd_handout ;;
  up) cmd_up ;; down) cmd_down ;; status) cmd_status ;; doctor) cmd_doctor ;;
  code-status|repos) shift 2>/dev/null || true; cmd_code_status "$@" ;;
  prod-health|health) shift 2>/dev/null || true; cmd_prod_health "$@" ;;
  deploy) shift; cmd_deploy "$@" ;;
  cockpit|panel) cmd_cockpit ;;
  console) cmd_console ;; app) cmd_app ;; dockapp) cmd_dockapp ;; menubar) cmd_menubar ;;
  demo) cmd_demo ;; install) cmd_install ;;
  ask) shift; cmd_ask "$@" ;; ingest) shift; cmd_ingest "$@" ;;
  backup) shift; cmd_backup "$@" ;; restore) shift; cmd_restore "$@" ;;
  outdated) cmd_outdated ;; update) shift; cmd_update "$@" ;; sync) cmd_sync ;;
  token) shift; cmd_token "$@" ;; logs) shift; cmd_logs "$@" ;;
  *) usage ;;
esac
