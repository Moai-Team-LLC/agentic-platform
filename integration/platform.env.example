# The Agentic Platform — one config for the whole ecosystem.
# Copy to ../.env (repo root) — `agentic up` fills the blanks on first run.
# Never commit real secrets.

# ── The one provider key. Every LLM call in the platform flows through
#    AgenticGateway, which routes to this upstream (OpenRouter by default). ──
OPENROUTER_API_KEY=

# ── Generated on first `agentic up` if left empty (openssl rand -hex 32). ──
AUTH_SECRET=
AGW_VAULT_KEY=
SIGNAL_SECRET=

# ── Service ports (host) ──
MIND_PORT=3000
APL_INGEST_PORT=4319
GATEWAY_PORT=8787
BIFROST_PORT=8080
CONSOLE_PORT=4600

# ── Postgres host ports ──
MIND_PG_PORT=5435
APL_PG_PORT=5439

# ── Embeddings run in a dedicated Ollama service (bge-m3, 1024-dim) so Mind
#    doesn't hold the model in-process; Ollama loads on demand, unloads when idle. ──
EMBED_CACHE_DIR=${HOME}/.cache/agenticmind-embed

# ── Isolation: compose project prefix — keeps platform volumes from
#    colliding with any same-named product clone elsewhere on disk. ──
COMPOSE_PREFIX=agentic-platform
