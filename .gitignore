# secrets & runtime — never commit
.env
.run/
*.log
backups/
handout.md
# personal dev-cockpit registry (holds prod IPs + ssh-key refs) — lives in
# ~/.agentic-cockpit, never in-repo. Belt-and-suspenders if one lands here.
.agentic-cockpit/
repos.json

# deps & build
node_modules/
**/node_modules/
console/**/node_modules/

# per-service rendered config (written by `agentic up`)
vendor/*/.env
vendor/*/.env.local
vendor/*/apps/*/.env.local
vendor/*/data/

# scan artifacts
examples/**/*.sarif
examples/**/*.md.out

.DS_Store
